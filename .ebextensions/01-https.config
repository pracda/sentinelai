# HTTPS with self-signed certificate for EB SingleInstance (no ALB).
# Traffic: browser:443 → nginx:443 (TLS) → container:8000 (HTTP)
# For a real cert: replace the openssl command with your ACM/Let's Encrypt cert files.

files:
  "/etc/nginx/conf.d/https.conf":
    mode: "000644"
    owner: root
    group: root
    content: |
      server {
          listen 443 ssl;
          server_name _;

          ssl_certificate     /etc/ssl/sentinelai/server.crt;
          ssl_certificate_key /etc/ssl/sentinelai/server.key;
          ssl_protocols       TLSv1.2 TLSv1.3;
          ssl_ciphers         HIGH:!aNULL:!MD5;

          # Long timeouts for SSE streaming and LLM calls
          proxy_read_timeout  310s;
          proxy_send_timeout  310s;

          location / {
              proxy_pass         http://localhost:8000;
              proxy_http_version 1.1;
              proxy_set_header   Host              $host;
              proxy_set_header   X-Real-IP         $remote_addr;
              proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
              proxy_set_header   X-Forwarded-Proto https;
              # Required for SSE — disable buffering so chunks reach the browser immediately
              proxy_buffering    off;
              proxy_cache        off;
              proxy_set_header   Connection        '';
              chunked_transfer_encoding on;
          }
      }

      server {
          listen 80;
          return 301 https://$host$request_uri;
      }

commands:
  01_mkdir_ssl:
    command: mkdir -p /etc/ssl/sentinelai
  02_generate_cert:
    command: >
      openssl req -x509 -nodes -days 730 -newkey rsa:2048
      -keyout /etc/ssl/sentinelai/server.key
      -out    /etc/ssl/sentinelai/server.crt
      -subj   "/C=US/O=SentinelAI/CN=sentinelai"
    test: "[ ! -f /etc/ssl/sentinelai/server.crt ]"
  03_reload_nginx:
    command: "nginx -s reload || true"

Resources:
  sslSecurityGroupIngress:
    Type: AWS::EC2::SecurityGroupIngress
    Properties:
      GroupId: {"Fn::GetAtt": ["AWSEBSecurityGroup", "GroupId"]}
      IpProtocol: tcp
      ToPort: 443
      FromPort: 443
      CidrIp: "0.0.0.0/0"
