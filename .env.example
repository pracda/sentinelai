# Copy to .env — never commit .env

# LLM providers (direct — used as fallback when gateway is disabled)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# LLM API Gateway (github.com/pracda/llm-api-gateway)
# 1. In the gateway admin panel: create an Org, generate an API key for it
# 2. Paste that key as LLM_GATEWAY_API_KEY and flip ENABLED to true
# Direct Anthropic is the automatic fallback if the gateway is unreachable.
LLM_GATEWAY_ENABLED=false
LLM_GATEWAY_URL=http://localhost:8080
LLM_GATEWAY_API_KEY=gw_your_key_here

# Threat intelligence APIs (free tiers available)
ABUSEIPDB_API_KEY=your-key-here
# Get free key at: https://www.abuseipdb.com/register
# NVD API key (optional, increases rate limits)
NVD_API_KEY=your-key-here
# Get free key at: https://nvd.nist.gov/developers/request-an-api-key

# App config
SENTINELAI_ENV=development
SENTINELAI_LOG_LEVEL=INFO
SENTINELAI_MAX_SCAN_THREADS=4

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite:///./sentinelai.db
